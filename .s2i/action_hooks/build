#!/bin/bash
set -e

echo "===> Overriding Apache DocumentRoot and disabling default welcome page..."

# 1. Update DocumentRoot in main httpd.conf to point to public/
if [ -f "/etc/httpd/conf/httpd.conf" ]; then
    sed -i 's|DocumentRoot "/opt/app-root/src"|DocumentRoot "/opt/app-root/src/public"|g' /etc/httpd/conf/httpd.conf
fi

# 2. Disable default Red Hat welcome page
if [ -f "/etc/httpd/conf.d/welcome.conf" ]; then
    echo "" > /etc/httpd/conf.d/welcome.conf
fi

# 3. Allow htaccess overrides in /opt/app-root/src/public
cat <<EOF > /etc/httpd/conf.d/laravel.conf
<Directory "/opt/app-root/src/public">
    Options Indexes FollowSymLinks
    AllowOverride All
    Require all granted
</Directory>
EOF