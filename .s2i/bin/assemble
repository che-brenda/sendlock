#!/bin/bash
set -e

echo "===> SendLock custom S2I assemble"

# 1. Standard sclorg PHP assemble (composer install --no-dev, fix-permissions).
/usr/libexec/s2i/assemble

cd /opt/app-root/src

# 2. Build the frontend assets. Every Blade view uses @vite(), so without a
#    Vite manifest (public/build/manifest.json) the whole app 500s. The PHP
#    builder ships Node/npm but never runs them, so we do it here.
export NPM_CONFIG_CACHE=/tmp/.npm
npm ci --no-audit --no-fund
npm run build

# 3. OpenShift runs the container as a random, non-root UID that belongs to the
#    root group, so every path the app writes to must be group-writable.
#    storage/ + bootstrap/cache/ are Laravel's; database/ holds the SQLite file.
mkdir -p database storage/framework/{cache,sessions,views}
chmod -R g+rwX storage bootstrap/cache database

# 4. Public storage symlink (ignored if it already exists).
php artisan storage:link || true

# 5. Database schema + seed data are handled at RUNTIME by .s2i/bin/run (against
#    the persistent Postgres service, so data survives rebuilds), NOT here at
#    build time. We deliberately do NOT create/migrate a baked SQLite file — that
#    reset all data on every rebuild. See .s2i/bin/run for the migrate + seed step.

echo "===> assemble complete"
