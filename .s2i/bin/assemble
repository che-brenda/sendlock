#!/bin/bash
set -e

echo "===> Running custom S2I assemble script..."

# 1. Run standard OpenShift assemble process
/usr/libexec/s2i/assemble

# 2. Grant group-write permissions (required for OpenShift random UIDs)
chmod -R g+rwX storage bootstrap/cache

# 3. Create storage link if missing
if [ ! -L "public/storage" ]; then
    php artisan storage:link || true
fi

# 4. Run migrations
php artisan migrate --force || true