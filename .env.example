APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SendLock recipient verification.
# Default 'log' writes codes to the application log (free, no external account).
# Set to 'twilio' and fill the credentials below to send real SMS / WhatsApp
# codes (Twilio charges per message). Leaving any credential blank keeps the
# log fallback, so nothing is sent or billed.
SENDLOCK_VERIFICATION_DRIVER=log
SENDLOCK_VERIFICATION_TTL=15
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Attachment OCR. Default 'null' extracts nothing (no binary required). Set to
# 'tesseract' to read uploaded images/scans with the self-hosted Tesseract binary
# (must be installed and on PATH — free, no external service).
SENDLOCK_OCR_DRIVER=null
TESSERACT_BINARY=tesseract
SENDLOCK_OCR_TIMEOUT=30

# External threat-intelligence feeds (free-tier). Comma-separated list of feeds
# to consult for domains not on the curated list; empty = no external calls.
# Each feed also needs its API key set, else it stays inactive. Verdicts are
# cached for SENDLOCK_THREAT_CACHE_TTL minutes (VirusTotal free tier is ~4/min).
SENDLOCK_THREAT_FEEDS=
SENDLOCK_THREAT_CACHE_TTL=720
GOOGLE_SAFE_BROWSING_KEY=
VIRUSTOTAL_API_KEY=

# Bulk phishing-list importer (sendlock:import-threat-feeds, scheduled hourly).
# Comma-separated list of feeds to import; empty = importer is a no-op.
SENDLOCK_THREAT_LISTS=
PHISHTANK_API_KEY=

# AI content classification. 'null' (default) contributes nothing. 'gemini' uses
# Google's free-tier Gemini API (beta); 'claude' uses the Anthropic API (paid,
# production) — same contract, just a driver swap. Needs the matching API key.
SENDLOCK_AI_DRIVER=null
SENDLOCK_AI_TIMEOUT=12
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Production AI (paid). SENDLOCK_AI_DRIVER=claude + an Anthropic API key. Model
# defaults to claude-opus-4-8; override with ANTHROPIC_MODEL (e.g. claude-haiku-4-5).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
