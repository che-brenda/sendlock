# SendLock — production environment profile (OpenShift).
#
# This file documents the values the app needs in production. On OpenShift these
# are NOT delivered as a .env file: non-secret values live in the ConfigMap
# (openshift/configmap.yaml) and secrets in the `sendlock-secrets` Secret — see
# openshift/README.md. This template exists so the two stay reviewable in one place.

APP_NAME=SendLock
APP_ENV=production
# Generate with: php artisan key:generate --show   (store in the Secret)
APP_KEY=
APP_DEBUG=false
# The public Route host, e.g. https://sendlock.apps.<cluster-domain>
APP_URL=https://sendlock.example.com

# The OpenShift router terminates TLS; trust its forwarded headers.
TRUSTED_PROXIES=*

BCRYPT_ROUNDS=12

# Containers must log to stderr so `oc logs` sees them; file logs die with the pod.
LOG_CHANNEL=stderr
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=pgsql
DB_HOST=sendlock-postgresql
DB_PORT=5432
DB_DATABASE=sendlock
# From the Secret:
DB_USERNAME=
DB_PASSWORD=

# Database-backed session/cache/queue keep pods stateless (no Redis required,
# multiple replicas work without sticky sessions).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# Mail is still the log driver until a real mailer is chosen — password resets
# and notifications will NOT be delivered. Swap to smtp/ses/etc. when ready.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@sendlock.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- SendLock drivers ---------------------------------------------------------
# All default to free/log/null drivers; enable per environment as credentials
# and entitlements are provisioned (see .env.example for full documentation).
SENDLOCK_VERIFICATION_DRIVER=log
SENDLOCK_VERIFICATION_TTL=15
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# 'tesseract' requires the binary in the image (not installed by default).
SENDLOCK_OCR_DRIVER=null

SENDLOCK_THREAT_FEEDS=
SENDLOCK_THREAT_CACHE_TTL=720
GOOGLE_SAFE_BROWSING_KEY=
VIRUSTOTAL_API_KEY=
SENDLOCK_THREAT_LISTS=
PHISHTANK_API_KEY=

SENDLOCK_AI_DRIVER=null
SENDLOCK_AI_TIMEOUT=12
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
